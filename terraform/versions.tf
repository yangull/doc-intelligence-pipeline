terraform {
  required_version = ">= 1.5"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      Project     = "doc-intelligence-pipeline"
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }
}